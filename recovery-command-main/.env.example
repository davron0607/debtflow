# DebtFlow — переменные окружения (Railway → Variables)

# PostgreSQL. На Railway: ${{Postgres.DATABASE_URL}} (reference variable)
DATABASE_URL="postgresql://postgres:debtflow_dev@localhost:5434/debtflow"

# Демо-режим: true — включён переключатель ролей и демо-подсказки на логине.
# В production ставить false.
DEMO_MODE=true

# Порт назначает Railway автоматически; локально можно переопределить
# PORT=8091

# Resend (https://resend.com) — транзакционная почта:
# приглашения пользователей, уведомления об SLA/обещаниях, отчёты
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
MAIL_FROM="DebtFlow <noreply@debtflow.uz>"

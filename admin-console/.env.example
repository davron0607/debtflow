# DebtFlow · Консоль оператора платформы
# Отдельное приложение, отдельный деплой (Railway service), отдельный домен
# (например admin.debtflow.uz) — сознательно НЕ тот же фронтенд/сессия/cookie,
# что у банков и агентств. См. scripts/create-admin-console-role.sql в корне
# монорепозитория для ограниченной роли Postgres.

# Строка подключения ОГРАНИЧЕННОЙ роли (не владельца БД!):
# postgresql://debtflow_admin_console:<пароль>@<host>:<port>/<db>
DATABASE_URL="postgresql://debtflow_admin_console:CHANGE_ME@localhost:5434/debtflow"

# Resend — уведомления по решениям модерации/приостановки
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
MAIL_FROM="DebtFlow <noreply@debtflow.uz>"

# НЕ добавлять NODE_ENV сюда: любое значение в .env читается и во время
# `npm run build`, и явное NODE_ENV=development ломает prod JSX-рантайм.
